extends layout

block content
  h2.page-title Community Members
  
  if users.length == 0
    p No users found.
  else
    div.food-grid
      each user in users
        div.food-card(style="text-align: center; padding-top: 1.5rem;")
          div(style="width: 80px; height: 80px; background: var(--primary-light); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto; font-weight: bold;") 
            = (user.username && user.username.length > 0) ? user.username.charAt(0).toUpperCase() : 'U'
          div.card-body
            h4= user.username || 'Unknown User'
            p Member since: #{user.created_at ? new Date(user.created_at).toLocaleDateString() : 'N/A'}
            div(style="margin-top: 1rem;")
              a.btn.btn-secondary(href=`/users/${user.id}`) View Profile
