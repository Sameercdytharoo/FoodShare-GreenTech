extends layout

block content
  .container.mt-5
    .row.justify-content-center
      .col-md-6
        .card
          .card-header
            h3 Login to FoodShare
          .card-body
            if error
              .alert.alert-danger= error
            
            form(action="/login" method="POST")
              .mb-3
                label.form-label(for="email") Email Address
                input#email.form-control(type="email" name="email" required placeholder="e.g. sameer@example.com")
              .mb-3
                label.form-label(for="password") Password
                input#password.form-control(type="password" name="password" required placeholder="e.g. hashedpassword123")
              button.btn.btn-primary.w-100(type="submit") Login
