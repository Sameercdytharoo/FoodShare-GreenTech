extends layout

block content
  h2.page-title= item.title || 'Food Item'
  
  div.item-detail-view(style="display: flex; gap: 2rem; background: #fff; padding: 2rem; border-radius: 12px; box-shadow: var(--shadow-md); margin-bottom: 2rem; flex-wrap: wrap;")
    div(style="flex: 1; min-width: 250px;")
      img(src=item.image_url || '/img/default-food.png', alt=item.title, style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px;")
    
    div(style="flex: 2; display: flex; flex-direction: column; min-width: 300px;")
      h3 Description
      p= item.description || 'No description provided.'
      
      div(style="margin-top: 1.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;")
        div
          strong Category: 
          span.card-category= item.category_name || 'Uncategorized'
        div
          strong Status: 
          span.card-status= item.status ? item.status.toUpperCase() : 'UNKNOWN'
        div
          strong Expiry Date: 
          span= item.expiry_date ? new Date(item.expiry_date).toLocaleString() : 'N/A'
        div
          strong Donated By: 
          a(href=`/users/${item.donor_id}`)= item.donor_name || 'Unknown'

      div(style="margin-top: auto; padding-top: 2rem;")
        if item.status === 'available'
          form(action="/api/claim" method="POST" style="display:inline;")
            input(type="hidden", name="item_id", value=item.id)
            input(type="hidden", name="receiver_id", value="2") 
            button.btn.btn-primary(type="submit", style="font-size: 1.1rem; padding: 1rem 2rem;") Claim This Item
        else
          button.btn.btn-secondary(disabled, style="font-size: 1.1rem; padding: 1rem 2rem; opacity: 0.6;") Already Claimed
